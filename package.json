{
  "name": "@piloto/app",
  "version": "0.1.0",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "vite build && electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:canary": "vite build && electrobun build --env=canary",
    "build:stable": "vite build && electrobun build --env=stable",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "bun run lint && bun x tsc --noEmit",
    "check:fix": "biome check --write . && bun x tsc --noEmit",
    "test": "bun test",
    "scaffold:module": "bun scripts/scaffold-module.ts",
    "scaffold:rpc": "bun scripts/scaffold-rpc.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepare": "bun scripts/install-hooks.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "electrobun": "^1.16.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bun": "^1.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  },
  "optionalDependencies": {
    "@parcel/watcher-android-arm64": "2.5.6",
    "@parcel/watcher-darwin-arm64": "2.5.6",
    "@parcel/watcher-darwin-x64": "2.5.6",
    "@parcel/watcher-freebsd-x64": "2.5.6",
    "@parcel/watcher-linux-arm-glibc": "2.5.6",
    "@parcel/watcher-linux-arm-musl": "2.5.6",
    "@parcel/watcher-linux-arm64-glibc": "2.5.6",
    "@parcel/watcher-linux-arm64-musl": "2.5.6",
    "@parcel/watcher-linux-x64-glibc": "2.5.6",
    "@parcel/watcher-linux-x64-musl": "2.5.6",
    "@parcel/watcher-win32-arm64": "2.5.6",
    "@parcel/watcher-win32-ia32": "2.5.6",
    "@parcel/watcher-win32-x64": "2.5.6"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
